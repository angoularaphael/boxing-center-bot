# boxing-center-bot — Bothosting : copier vers /home/container/.env
# Local : cp .env.example .env
#
# Sur Vercel (gestion-manager), pas ici : NEXT_PUBLIC_WHATSAPP_BOT_URL=http://us2.bot-hosting.net:20042

# ── Serveur ───────────────────────────────────────────────────────────────────
PORT=20042
SERVER_PORT=20042

# Identifiant serveur (minimes | st_cyprien | ramonville) — affiché dans les discussions campagne
BOT_INSTANCE_ID=minimes
# WA_BULK_MAX_PER_HOUR=13

# ── Lien site ↔ bot (comme NYC Cookies) ───────────────────────────────────────
SITE_API_SECRET=
NEXT_PUBLIC_SITE_URL=https://gestion-manager.vercel.app

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://ulxtbvxdueolvnjhpzvw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# ── Envoi test campagnes ───────────────────────────────────────────────────────
CAMPAIGN_TEST_EMAIL=giffareno237@gmail.com

# ── WhatsApp — admin permanent ────────────────────────────────────────────────
MANDATORY_ADMIN_PHONE=33762641473

# ── Envoi WhatsApp en masse (évite blocage ~24 h) ───────────────────────────
# Délai entre chaque numéro (ms) + jitter aléatoire. Max envois / heure.
# WA_BULK_DELAY_MS=50000
# WA_BULK_DELAY_JITTER_MS=20000
# WA_BULK_MAX_PER_HOUR=12

# ── Brevo SMTP (clé xsmtpsib) ─────────────────────────────────────────────────
BREVO_SMTP_LOGIN=
BREVO_SMTP_KEY=
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SENDER_EMAIL=suzinabot@11426075.brevosend.com
BREVO_SENDER_NAME=Boxing Center

# ── Marque / contact ──────────────────────────────────────────────────────────
BOXING_CENTER_SITE_URL=https://boxingcenter.fr/
BOXING_CENTER_CONTACT_EMAIL=boxingcenter31@gmail.com
RECEPTION_EMAIL=boxingcenter31@gmail.com
BREVO_REPLY_TO=boxingcenter31@gmail.com
