# Copier vers .env — boxing-center-bot
# cp .env.example .env  (puis remplir les clés vides)

# ── Serveur ───────────────────────────────────────────────────────────────────
PORT=20042
SERVER_PORT=20042

# ── Lien avec gestion-manager (Vercel) ────────────────────────────────────────
# Même valeur que SITE_API_SECRET sur gestion-manager / env.vercel
SITE_API_SECRET=
NEXT_PUBLIC_SITE_URL=https://gestion-manager.vercel.app

# ── URL publique du bot ───────────────────────────────────────────────────────
# Local : http://localhost:20042  |  Bothosting : http://us2.bot-hosting.net:20042
# Vercel : utiliser l’URL HTTPS affichée au démarrage si CLOUDFLARE_TUNNEL=true
BOT_PUBLIC_URL=http://us2.bot-hosting.net:20042
NEXT_PUBLIC_WHATSAPP_BOT_URL=http://us2.bot-hosting.net:20042

# ── Tunnel HTTPS Cloudflare (requis pour Vercel — ports 80/443 uniquement) ───
CLOUDFLARE_TUNNEL=true

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://ulxtbvxdueolvnjhpzvw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# ── WhatsApp — admin permanent ────────────────────────────────────────────────
MANDATORY_ADMIN_PHONE=33762641473

# ── Brevo — Option A : SMTP (recommandé, clé xsmtpsib-…) ─────────────────────
BREVO_SMTP_LOGIN=
BREVO_SMTP_KEY=
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587

# ── Brevo — Option B : API REST (clé xkeysib-…, pas la clé SMTP) ─────────────
# BREVO_API_KEY=

BREVO_SENDER_EMAIL=suzinabot@11426075.brevosend.com
BREVO_SENDER_NAME=Boxing Center

# ── Marque / contact ──────────────────────────────────────────────────────────
BOXING_CENTER_SITE_URL=https://boxingcenter.fr/
BOXING_CENTER_CONTACT_EMAIL=boxingcenter31@gmail.com
RECEPTION_EMAIL=boxingcenter31@gmail.com
BREVO_REPLY_TO=boxingcenter31@gmail.com
